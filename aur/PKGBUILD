# Maintainer: Bimbok <your-email@example.com>
pkgname=fyzenor
pkgver=3.0.0
pkgrel=1
pkgdesc="A modern, blazing-fast terminal file manager built in C++ with live previews and async workflows"
arch=('x86_64' 'aarch64')
url="https://github.com/Bimbok/fyzenor"
license=('MIT')
depends=('ncurses' 'ffmpeg' 'zip' 'bat' 'ripgrep')
makedepends=('cmake' 'make' 'gcc')
source=("git+https://github.com/Bimbok/fyzenor.git#tag=v${pkgver}")
md5sums=('SKIP')

build() {
  cmake -B build -S "$pkgname" -DCMAKE_BUILD_TYPE=Release
  cmake --build build
}

package() {
  # Install the main binary
  install -Dm755 build/fyzenor "$pkgdir/usr/bin/fyzenor"
  
  # Create the "fm" symlink
  ln -sf fyzenor "$pkgdir/usr/bin/fm"
  
  # Install the Desktop file & Icon
  install -Dm644 "$pkgname/Sample/fyzenor.desktop" "$pkgdir/usr/share/applications/fyzenor.desktop"
  install -Dm644 "$pkgname/fyzenor.png" "$pkgdir/usr/share/pixmaps/fyzenor.png"
  
  # Install the License
  install -Dm644 "$pkgname/LICENSE" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
